---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CommunityPage from "../../components/pages/CommunityPage.astro";
import { COMMUNITY_MESSAGES } from "../../locales/community";
import { DEFAULT_LANG } from "../../config/i18n";

const lang = DEFAULT_LANG;
const messages = COMMUNITY_MESSAGES[lang];
---
<BaseLayout lang={lang} title={`MindQuantum – ${messages.title}`} description={messages.subtitle}>
  <CommunityPage lang={lang} messages={messages} />
</BaseLayout>
