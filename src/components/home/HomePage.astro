---
import type { Lang } from "../../config/i18n";
import type { HomeMessages } from "../../locales/home";

import HeroCarousel from "./HeroCarousel.astro";
import AnnouncementBar from "./AnnouncementBar.astro";
import FrameworkIntro from "./FrameworkIntro.astro";
import Features from "./Features.astro";
import Research from "./Research.astro";
import StartLearning from "./StartLearning.astro";
import CTABanner from "./CTABanner.astro";

interface Props {
  lang: Lang;
  messages: HomeMessages;
  baseUrl: string;
}

const { messages } = Astro.props as Props;
---

<HeroCarousel slides={messages.hero.slides} />
<AnnouncementBar announcement={messages.announcement} />
<FrameworkIntro architecture={messages.architecture} framework={messages.framework} />
<Features features={messages.features} />
<Research research={messages.research} />
<StartLearning learning={messages.learning} />
<CTABanner cta={messages.cta} />
