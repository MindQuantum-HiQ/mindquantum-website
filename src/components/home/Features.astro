---
import { Image } from "astro:assets";
import featureVisual from "../../assets/home/feature-visual-circuit.jpg";
import featureHybrid from "../../assets/home/feature-hybrid.jpg";
import featureSimulation from "../../assets/home/feature-simulation.jpg";
import featureAlgorithm from "../../assets/home/feature-algorithm.jpg";
import type { HomeMessages } from "../../locales/home";

interface Props {
  features: HomeMessages["features"];
}

const { features } = Astro.props as Props;

const IMAGES = {
  visual: featureVisual,
  hybrid: featureHybrid,
  simulation: featureSimulation,
  algorithm: featureAlgorithm,
};
---

<section class="mq-container mb-16">
  <h2 class="mq-section-title mb-10">{features.heading}</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {features.items.map((feature) => (
      <article class="group text-center">
        <div class="relative rounded-xl overflow-hidden mb-4 aspect-[4/3] bg-muted">
          <Image
            src={IMAGES[feature.image]}
            alt={feature.title}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
            widths={[320, 480, 640]}
            sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 90vw"
          />
        </div>
        <h3 class="font-semibold text-foreground mb-2">{feature.title}</h3>
        <p class="text-sm text-muted-foreground leading-relaxed">{feature.description}</p>
      </article>
    ))}
  </div>
</section>
