---
import type { HomeMessages } from "../../locales/home";
import { withBase } from "../../config/urls";

interface Props {
  architecture: HomeMessages["architecture"];
  framework: HomeMessages["framework"];
}

const { architecture, framework } = Astro.props as Props;
const BASE = import.meta.env.BASE_URL || "/";
const releaseHref = /^https?:\/\//.test(framework.releaseHref)
  ? framework.releaseHref
  : withBase(framework.releaseHref, BASE);

function resolveHref(href: string): string {
  return /^https?:\/\//.test(href) ? href : withBase(href, BASE);
}
---

<section class="mq-container mb-20">
  <div class="grid md:grid-cols-2 gap-10 lg:gap-12 items-start">
    <div class="mq-card bg-background p-6">
      <table class="w-full text-xs md:text-sm border-collapse">
        <thead>
          <tr>
            <th class="w-[30%]"></th>
            {architecture.columnHeaders.map((header) => (
              <th class="text-center font-semibold text-foreground pb-3 px-1">
                {header}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {architecture.rows.map((row) => (
            <tr class="border-t border-border/60">
              <th scope="row" class="text-left font-semibold text-foreground py-2 pr-3 whitespace-normal align-top">
                {row.label}
              </th>
              {row.cells.map((cell) => (
                <td class="py-3 px-2 align-top text-center text-xs md:text-sm text-muted-foreground">
                  {cell ? (
                    row.href ? (
                      <a
                        href={resolveHref(row.href)}
                        class="block transition-colors hover:text-foreground hover:underline underline-offset-4 decoration-border hover:decoration-foreground/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring rounded-sm"
                      >
                        {cell}
                      </a>
                    ) : (
                      <span class="block">{cell}</span>
                    )
                  ) : (
                    <span class="block text-muted-foreground/40" aria-hidden="true">—</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div>
      <a href={releaseHref} class="mq-link-arrow text-sm">
        {framework.release}
        <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6l6 6l-6 6" /></svg>
      </a>
      <p class="mq-measure mt-4 text-sm leading-relaxed text-muted-foreground">
        {framework.description}
      </p>
      <div class="mt-6 flex flex-wrap gap-3 items-center">
        <button
          type="button"
          class="mq-btn-run gap-2 font-mono text-sm"
          data-install-copy
          data-copy-text={framework.installCmd}
          data-copied-label={framework.installCopiedLabel}
          data-manual-label={framework.installManualLabel}
          aria-label={`Copy ${framework.installCmd}`}
        >
          <span data-install-label>{framework.installCmd}</span>
          <svg aria-hidden="true" class="w-3.5 h-3.5 opacity-80" viewBox="0 0 24 24">
            <path fill="currentColor" d="M9 2h9a2 2 0 0 1 2 2v13h-2V4H9V2Zm-4 4h9a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm0 2v13h9V8H5Z" />
          </svg>
        </button>
        <a href={releaseHref} class="mq-btn-outline">
          {framework.docsLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    document.querySelectorAll<HTMLButtonElement>("[data-install-copy]").forEach((button) => {
      const text = button.getAttribute("data-copy-text") || "";
      const copiedLabel = button.getAttribute("data-copied-label") || "Copied";
      const manualLabel =
        button.getAttribute("data-manual-label") ||
        "Copy failed \u2014 press \u2318C / Ctrl+C";
      const labelEl = button.querySelector<HTMLElement>("[data-install-label]");
      const originalLabel = labelEl?.textContent || text;

      function flashLabel(label: string, holdMs: number) {
        if (labelEl) labelEl.textContent = label;
        button.classList.remove("mq-flash");
        void button.offsetWidth;
        button.classList.add("mq-flash");
        setTimeout(() => {
          if (labelEl) labelEl.textContent = originalLabel;
          button.classList.remove("mq-flash");
          button.removeAttribute("data-copy-state");
        }, holdMs);
      }

      button.addEventListener("click", async () => {
        try {
          if (!navigator.clipboard || !navigator.clipboard.writeText) {
            throw new Error("clipboard unavailable");
          }
          await navigator.clipboard.writeText(text);
          button.setAttribute("data-copy-state", "success");
          flashLabel(copiedLabel, 1500);
        } catch (_) {
          // Clipboard blocked (insecure context, permission, or old browser).
          // Surface the failure with a readable hint rather than silently
          // swallowing it, and select the command text so the user can
          // copy it manually with a keyboard shortcut.
          button.setAttribute("data-copy-state", "error");
          try {
            const range = document.createRange();
            if (labelEl) range.selectNodeContents(labelEl);
            const sel = window.getSelection();
            sel?.removeAllRanges();
            if (labelEl) sel?.addRange(range);
          } catch (_err) {
            /* selection unavailable */
          }
          flashLabel(manualLabel, 2800);
        }
      });
    });
  })();
</script>
