---
import type { HomeMessages } from "../../locales/home";
import { withBase } from "../../config/urls";

interface Props {
  architecture: HomeMessages["architecture"];
  framework: HomeMessages["framework"];
}

const { architecture, framework } = Astro.props as Props;
const BASE = import.meta.env.BASE_URL || "/";
const releaseHref = /^https?:\/\//.test(framework.releaseHref)
  ? framework.releaseHref
  : withBase(framework.releaseHref, BASE);
---

<section class="mq-container mb-16">
  <div class="grid md:grid-cols-2 gap-8 items-start">
    <div class="mq-card bg-background p-6">
      <table class="w-full text-xs md:text-sm border-collapse">
        <thead>
          <tr>
            <th class="w-[30%]"></th>
            {architecture.columnHeaders.map((header) => (
              <th class="text-center font-semibold text-foreground pb-3 px-1">
                {header}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {architecture.rows.map((row) => (
            <tr class="border-t border-border/60">
              <th scope="row" class="text-left font-semibold text-foreground py-2 pr-3 whitespace-normal align-top">
                {row.label}
              </th>
              {row.cells.map((cell) => (
                <td class="py-2 px-1 align-top">
                  {cell ? (
                    <span class="block border border-dashed border-primary/40 rounded-md px-2 py-1.5 text-muted-foreground text-center text-[11px] md:text-xs">
                      {cell}
                    </span>
                  ) : (
                    <span class="block" aria-hidden="true">&nbsp;</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div>
      <a href={releaseHref} class="mq-link-arrow text-sm">
        {framework.release}
        <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6l6 6l-6 6" /></svg>
      </a>
      <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
        {framework.description}
      </p>
      <div class="mt-6 flex flex-wrap gap-3 items-center">
        <button
          type="button"
          class="mq-btn-primary gap-2 font-mono text-sm"
          data-install-copy
          data-copy-text={framework.installCmd}
          data-copied-label={framework.installCopiedLabel}
          aria-label={`Copy ${framework.installCmd}`}
        >
          <span data-install-label>{framework.installCmd}</span>
          <svg aria-hidden="true" class="w-3.5 h-3.5 opacity-80" viewBox="0 0 24 24">
            <path fill="currentColor" d="M9 2h9a2 2 0 0 1 2 2v13h-2V4H9V2Zm-4 4h9a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Zm0 2v13h9V8H5Z" />
          </svg>
        </button>
        <a href={releaseHref} class="mq-btn-outline">
          {framework.docsLabel}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    document.querySelectorAll<HTMLButtonElement>("[data-install-copy]").forEach((button) => {
      const text = button.getAttribute("data-copy-text") || "";
      const copiedLabel = button.getAttribute("data-copied-label") || "Copied";
      const labelEl = button.querySelector<HTMLElement>("[data-install-label]");
      const originalLabel = labelEl?.textContent || text;
      button.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(text);
          if (labelEl) labelEl.textContent = copiedLabel;
          setTimeout(() => {
            if (labelEl) labelEl.textContent = originalLabel;
          }, 1500);
        } catch (_) {
          /* clipboard denied */
        }
      });
    });
  })();
</script>
