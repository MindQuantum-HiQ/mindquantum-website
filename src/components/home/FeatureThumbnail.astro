---
/*
 * Inline-SVG thumbnails for the Features section. Each diagram is hand-authored
 * and actually represents what the feature does — they replace the previous
 * stock-abstract webp imports that read as generic AI decoration.
 *
 * Color strategy:
 *   - `currentColor` drives neutral strokes + axis labels; it's set by the
 *     surrounding container via Tailwind `text-foreground/80`.
 *   - `hsl(var(--primary))` is the one emphasis color (amplified bars, loss
 *     curve, circuit wires, marked states).
 *   - No raw hex values — the thumbnails track every palette change.
 *
 * `size` gates label visibility: the primary 16:10 panel keeps axis labels so
 * the chart is readable, the compact 96 px thumbnails drop them to keep the
 * silhouette legible at the smaller size.
 */

type Kind = "visual" | "hybrid" | "simulation" | "algorithm";

interface Props {
  kind: Kind;
  size: "primary" | "compact";
  title: string;
}

const { kind, size, title } = Astro.props as Props;
const showLabels = size === "primary";
---

{kind === "visual" && (
  <svg
    viewBox="0 0 200 120"
    class="w-full h-full text-foreground/75"
    role="img"
    aria-label={title}
  >
    <title>{title}</title>
    {/* Two-qubit wires */}
    <line x1="8" y1="40" x2="192" y2="40" stroke="currentColor" stroke-width="1.5" />
    <line x1="8" y1="88" x2="192" y2="88" stroke="currentColor" stroke-width="1.5" />

    {/* |0> labels */}
    {showLabels && (
      <>
        <text x="4" y="44" font-size="10" font-family="JetBrains Mono, monospace" fill="currentColor">|0⟩</text>
        <text x="4" y="92" font-size="10" font-family="JetBrains Mono, monospace" fill="currentColor">|0⟩</text>
      </>
    )}

    {/* Hadamard gate on top qubit */}
    <rect x="36" y="28" width="22" height="22" rx="3" fill="hsl(var(--primary))" />
    <text x="47" y="44" text-anchor="middle" font-size="12" font-weight="600" font-family="JetBrains Mono, monospace" fill="hsl(var(--primary-foreground))">H</text>

    {/* CNOT */}
    <line x1="100" y1="40" x2="100" y2="88" stroke="currentColor" stroke-width="1.5" />
    <circle cx="100" cy="40" r="4.5" fill="currentColor" />
    <circle cx="100" cy="88" r="10" fill="none" stroke="currentColor" stroke-width="1.5" />
    <line x1="90" y1="88" x2="110" y2="88" stroke="currentColor" stroke-width="1.5" />
    <line x1="100" y1="78" x2="100" y2="98" stroke="currentColor" stroke-width="1.5" />

    {/* Measurements */}
    <rect x="148" y="28" width="22" height="22" rx="3" fill="none" stroke="currentColor" stroke-width="1.5" />
    <path d="M152 46 Q159 32 166 46" stroke="currentColor" stroke-width="1.3" fill="none" />
    <line x1="159" y1="46" x2="166" y2="34" stroke="currentColor" stroke-width="1.3" />

    <rect x="148" y="76" width="22" height="22" rx="3" fill="none" stroke="currentColor" stroke-width="1.5" />
    <path d="M152 94 Q159 80 166 94" stroke="currentColor" stroke-width="1.3" fill="none" />
    <line x1="159" y1="94" x2="166" y2="82" stroke="currentColor" stroke-width="1.3" />
  </svg>
)}

{kind === "hybrid" && (
  <svg
    viewBox="0 0 200 120"
    class="w-full h-full text-foreground/75"
    role="img"
    aria-label={title}
  >
    <title>{title}</title>
    {/* Axes */}
    <line x1="22" y1="12" x2="22" y2="102" stroke="currentColor" stroke-width="1" opacity="0.5" />
    <line x1="22" y1="102" x2="192" y2="102" stroke="currentColor" stroke-width="1" opacity="0.5" />

    {/* Target energy line */}
    <line x1="22" y1="90" x2="192" y2="90" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3" opacity="0.35" />

    {/* Convergence curve */}
    <path
      d="M28 24 C55 30 75 55 95 70 S140 90 190 92"
      stroke="hsl(var(--primary))"
      stroke-width="2.2"
      fill="none"
      stroke-linecap="round"
    />
    {/* Sample points */}
    <circle cx="28" cy="24" r="2.5" fill="hsl(var(--primary))" />
    <circle cx="65" cy="42" r="2.5" fill="hsl(var(--primary))" />
    <circle cx="95" cy="70" r="2.5" fill="hsl(var(--primary))" />
    <circle cx="130" cy="85" r="2.5" fill="hsl(var(--primary))" />
    <circle cx="170" cy="91" r="2.5" fill="hsl(var(--primary))" />

    {showLabels && (
      <>
        <text x="28" y="22" font-size="9" font-family="JetBrains Mono, monospace" fill="currentColor" opacity="0.7">⟨H⟩</text>
        <text x="170" y="115" font-size="9" font-family="JetBrains Mono, monospace" fill="currentColor" opacity="0.7">steps</text>
      </>
    )}
  </svg>
)}

{kind === "simulation" && (
  <svg
    viewBox="0 0 200 120"
    class="w-full h-full text-foreground/75"
    role="img"
    aria-label={title}
  >
    <title>{title}</title>
    {/* Baseline */}
    <line x1="8" y1="96" x2="192" y2="96" stroke="currentColor" stroke-width="1" opacity="0.4" />
    {/* CPU bar (shortest) */}
    <rect x="28" y="68" width="32" height="28" rx="2" fill="currentColor" opacity="0.32" />
    {/* GPU bar (mid) */}
    <rect x="84" y="36" width="32" height="60" rx="2" fill="hsl(var(--primary))" opacity="0.6" />
    {/* Ascend bar (tallest) */}
    <rect x="140" y="14" width="32" height="82" rx="2" fill="hsl(var(--primary))" />

    {showLabels && (
      <>
        <text x="44" y="112" text-anchor="middle" font-size="9" font-family="JetBrains Mono, monospace" fill="currentColor" opacity="0.75">CPU</text>
        <text x="100" y="112" text-anchor="middle" font-size="9" font-family="JetBrains Mono, monospace" fill="currentColor" opacity="0.75">GPU</text>
        <text x="156" y="112" text-anchor="middle" font-size="9" font-family="JetBrains Mono, monospace" fill="currentColor" opacity="0.75">Ascend</text>
      </>
    )}
  </svg>
)}

{kind === "algorithm" && (
  <svg
    viewBox="0 0 200 120"
    class="w-full h-full text-foreground/75"
    role="img"
    aria-label={title}
  >
    <title>{title}</title>
    {/* Baseline */}
    <line x1="10" y1="96" x2="190" y2="96" stroke="currentColor" stroke-width="1" opacity="0.4" />

    {/* 8 measurement-probability bars (3-qubit state). Bars 0 and 4 are
        amplified — think Grover picking |000> and |100> — so the diagram
        shows "quantum algorithm output" rather than a generic histogram. */}
    <g>
      <rect x="20" y="28" width="14" height="68" rx="1.5" fill="hsl(var(--primary))" />
      <rect x="42" y="82" width="14" height="14" rx="1.5" fill="currentColor" opacity="0.32" />
      <rect x="64" y="78" width="14" height="18" rx="1.5" fill="currentColor" opacity="0.32" />
      <rect x="86" y="84" width="14" height="12" rx="1.5" fill="currentColor" opacity="0.32" />
      <rect x="108" y="36" width="14" height="60" rx="1.5" fill="hsl(var(--primary))" opacity="0.85" />
      <rect x="130" y="80" width="14" height="16" rx="1.5" fill="currentColor" opacity="0.32" />
      <rect x="152" y="76" width="14" height="20" rx="1.5" fill="currentColor" opacity="0.32" />
      <rect x="174" y="86" width="14" height="10" rx="1.5" fill="currentColor" opacity="0.32" />
    </g>

    {showLabels && (
      <>
        <text x="27" y="112" text-anchor="middle" font-size="7" font-family="JetBrains Mono, monospace" fill="currentColor" opacity="0.65">000</text>
        <text x="115" y="112" text-anchor="middle" font-size="7" font-family="JetBrains Mono, monospace" fill="currentColor" opacity="0.65">100</text>
        <text x="181" y="112" text-anchor="middle" font-size="7" font-family="JetBrains Mono, monospace" fill="currentColor" opacity="0.65">111</text>
      </>
    )}
  </svg>
)}
