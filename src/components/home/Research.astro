---
import type { HomeMessages } from "../../locales/home";
import { withBase } from "../../config/urls";

interface Props {
  research: HomeMessages["research"];
}

const { research } = Astro.props as Props;
const BASE = import.meta.env.BASE_URL || "/";
const href = /^https?:\/\//.test(research.linkHref)
  ? research.linkHref
  : withBase(research.linkHref, BASE);
---

<section class="mq-container mb-20">
  <span class="mq-eyebrow">{research.heading}</span>
  <p class="mt-3 text-display-md font-semibold tracking-tight text-foreground mq-measure">
    {research.statement}
  </p>
  <a href={href} class="mq-link-arrow mt-6 text-sm">
    {research.linkLabel}
    <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24">
      <path
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M5 12h14m-6-6l6 6l-6 6"
      />
    </svg>
  </a>
</section>
