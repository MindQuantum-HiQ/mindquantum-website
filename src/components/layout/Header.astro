---
import { Image } from "astro:assets";
import logo from "../../assets/home/logo.png";
import LanguageSwitcher from "../LanguageSwitcher.astro";
import { NAV_MESSAGES } from "../../locales/nav";
import { CODE_MIRRORS } from "../../config/site";
import { type Lang } from "../../config/i18n";
import { withBase, pathForLang } from "../../config/urls";

interface Props {
  lang: Lang;
  pathUnbased: string;
}

const { lang, pathUnbased } = Astro.props;
const BASE = import.meta.env.BASE_URL || "/";
const nav = NAV_MESSAGES[lang];
const homeHref = withBase(pathForLang("/", lang), BASE);

const localized = (path: string) => withBase(pathForLang(path, lang), BASE);
const apiOverviewRel =
  lang === "en" ? "api_python_en/overview.html" : "api_python/overview.html";

type NavItem = {
  label: string;
  href: string;
  id: string;
  children?: Array<{ label: string; href: string; external?: boolean }>;
  groups?: Array<{
    title: string;
    items: Array<{ label: string; href: string; external?: boolean }>;
  }>;
};

const navItems: NavItem[] = [
  { id: "about", label: nav.about, href: homeHref },
  { id: "composer", label: nav.composer, href: localized("/composer/") },
  {
    id: "learning",
    label: nav.learning,
    href: localized("/learning/"),
    children: [
      { label: nav.learningItems.courses, href: localized("/learning/") },
      { label: nav.learningItems.videoCourses, href: withBase("/courses/", BASE) },
      { label: nav.learningItems.whitePaper, href: localized("/documentation/") },
      { label: nav.learningItems.paperCode, href: localized("/community/") },
    ],
  },
  {
    id: "documentation",
    label: nav.documentation,
    href: localized("/documentation/"),
    children: [
      { label: nav.documentation, href: localized("/documentation/") },
      { label: nav.docs, href: `${BASE}docs/${lang}/` },
      {
        label: nav.api,
        href: `${BASE}api/${lang}/#/${apiOverviewRel}`,
      },
    ],
  },
  { id: "benchmark", label: nav.benchmark, href: localized("/benchmark/") },
  {
    id: "community",
    label: nav.community,
    href: localized("/community/"),
    groups: [
      {
        title: nav.communityGroups.contribution,
        items: [
          {
            label: nav.communityItems.contributionGuide,
            href: "https://atomgit.com/mindspore/mindquantum",
            external: true,
          },
          {
            label: nav.communityItems.developerGrowth,
            href: "https://www.mindspore.cn/developers",
            external: true,
          },
        ],
      },
      {
        title: nav.communityGroups.competitions,
        items: [
          { label: nav.communityItems.internship, href: localized("/community/") },
          { label: nav.communityItems.hackathon, href: localized("/community/") },
        ],
      },
      {
        title: nav.communityGroups.resources,
        items: [
          {
            label: nav.communityItems.koushareStream,
            href: "https://www.koushare.com/",
            external: true,
          },
          {
            label: nav.communityItems.bilibiliStream,
            href: "https://www.bilibili.com/",
            external: true,
          },
          { label: nav.communityItems.paperLecture, href: localized("/community/") },
        ],
      },
    ],
  },
];

function isActive(itemHref: string, currentPath: string) {
  const a = itemHref.replace(/^\/+/, "").replace(/\/+$/, "");
  const b = currentPath.replace(/^\/+/, "").replace(/\/+$/, "");
  if (a === "" && b === "") return true;
  if (!a) return false;
  return b === a;
}
---

<header class="site-header sticky top-0 z-40 w-full border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/75">
  <div class="mq-container flex h-16 items-center gap-6">
    <a href={homeHref} class="flex items-center gap-2 shrink-0" aria-label="MindSpore Quantum home">
      <Image src={logo} alt="MindSpore Quantum" width={32} height={32} class="h-8 w-8 object-contain" loading="eager" />
      <span class="text-sm font-semibold leading-tight hidden sm:block">
        MindSpore<br />Quantum
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-1 flex-1" aria-label="Primary">
      {navItems.map((item) => {
        const hasDropdown = Boolean(item.children || item.groups);
        const active = isActive(item.href, Astro.url.pathname);
        return (
          <div class="nav-group relative">
            <a
              href={item.href}
              class:list={[
                "px-3 py-2 text-sm font-medium transition-colors inline-flex items-center gap-1",
                active
                  ? "text-primary after:absolute after:bottom-0 after:left-3 after:right-3 after:h-[2px] after:bg-primary"
                  : "text-foreground hover:text-primary",
              ]}
            >
              {item.label}
              {hasDropdown && (
                <svg aria-hidden="true" class="w-3 h-3 opacity-70" viewBox="0 0 24 24">
                  <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="m6 9l6 6l6-6" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="nav-menu absolute top-full left-0 mt-0 pt-1 min-w-[16rem] z-50" role="menu">
                <div class="rounded-xl border border-border bg-popover text-popover-foreground shadow-lg p-2">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      target={child.external ? "_blank" : undefined}
                      rel={child.external ? "noopener" : undefined}
                      class="block px-3 py-2 text-sm text-muted-foreground hover:text-primary hover:bg-secondary rounded-md"
                      role="menuitem"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
            {item.groups && (
              <div class="nav-menu absolute top-full left-0 mt-0 pt-1 min-w-[18rem] z-50" role="menu">
                <div class="rounded-xl border border-border bg-popover text-popover-foreground shadow-lg p-3 space-y-3">
                  {item.groups.map((group) => (
                    <div>
                      <p class="text-xs font-semibold text-foreground mb-1 px-2">{group.title}</p>
                      {group.items.map((sub) => (
                        <a
                          href={sub.href}
                          target={sub.external ? "_blank" : undefined}
                          rel={sub.external ? "noopener" : undefined}
                          class="block px-2 py-1.5 text-sm text-muted-foreground hover:text-primary hover:bg-secondary rounded-md"
                          role="menuitem"
                        >
                          {sub.label}
                        </a>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </nav>

    <div class="flex items-center gap-2 ml-auto">
      <div class="nav-group relative hidden md:block">
        <button type="button" class="inline-flex items-center gap-1 text-sm font-medium text-foreground hover:text-primary px-3 py-2" aria-haspopup="menu" aria-expanded="false" data-nav-toggle>
          {nav.code}
          <svg aria-hidden="true" class="w-3 h-3 opacity-70" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="m6 9l6 6l6-6" /></svg>
        </button>
        <div class="nav-menu absolute top-full right-0 mt-0 pt-1 min-w-[12rem] z-50" role="menu">
          <div class="rounded-xl border border-border bg-popover text-popover-foreground shadow-lg p-2">
            {CODE_MIRRORS.map((mirror) => (
              <a
                href={mirror.href}
                target="_blank"
                rel="noopener"
                class="flex items-center justify-between gap-3 px-3 py-2 text-sm text-muted-foreground hover:text-primary hover:bg-secondary rounded-md"
                role="menuitem"
              >
                <span>{mirror.label}</span>
                <svg aria-hidden="true" class="w-3.5 h-3.5 opacity-70" viewBox="0 0 24 24">
                  <path fill="currentColor" d="M14 3h7v7h-2V6.414l-9.293 9.293l-1.414-1.414L17.586 5H14V3ZM5 5h6v2H7v10h10v-4h2v6H5V5Z" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>

      <LanguageSwitcher lang={lang} />

      <button
        type="button"
        class="lg:hidden inline-flex items-center justify-center rounded-md p-2 text-foreground hover:bg-secondary"
        aria-label="Toggle navigation"
        data-mobile-toggle
      >
        <svg aria-hidden="true" class="w-5 h-5" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <div class="lg:hidden border-t border-border hidden" data-mobile-menu>
    <div class="mq-container py-3 flex flex-col gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block px-3 py-2 text-sm font-medium text-foreground hover:text-primary rounded-md"
        >
          {item.label}
        </a>
      ))}
      <div class="border-t border-border my-2"></div>
      {CODE_MIRRORS.map((mirror) => (
        <a
          href={mirror.href}
          target="_blank"
          rel="noopener"
          class="flex items-center justify-between px-3 py-2 text-sm text-muted-foreground hover:text-primary rounded-md"
        >
          <span>{nav.code} · {mirror.label}</span>
          <svg aria-hidden="true" class="w-3.5 h-3.5 opacity-70" viewBox="0 0 24 24">
            <path fill="currentColor" d="M14 3h7v7h-2V6.414l-9.293 9.293l-1.414-1.414L17.586 5H14V3ZM5 5h6v2H7v10h10v-4h2v6H5V5Z" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  // Simple dropdown + mobile menu behavior.
  (function () {
    const groups = document.querySelectorAll(".nav-group");
    groups.forEach((group) => {
      const el = group as HTMLElement;
      const toggle = el.querySelector("[data-nav-toggle]") as HTMLElement | null;
      const open = () => {
        el.classList.add("group-open");
        toggle?.setAttribute("aria-expanded", "true");
      };
      const close = () => {
        el.classList.remove("group-open");
        toggle?.setAttribute("aria-expanded", "false");
      };
      el.addEventListener("mouseenter", open);
      el.addEventListener("mouseleave", close);
      el.addEventListener("focusin", open);
      el.addEventListener("focusout", (e) => {
        if (!el.contains(e.relatedTarget as Node)) close();
      });
      if (toggle) {
        toggle.addEventListener("click", (e) => {
          e.preventDefault();
          if (el.classList.contains("group-open")) close();
          else open();
        });
      }
    });
    document.addEventListener("click", (e) => {
      groups.forEach((g) => {
        if (!(g as HTMLElement).contains(e.target as Node)) {
          (g as HTMLElement).classList.remove("group-open");
          const t = (g as HTMLElement).querySelector("[data-nav-toggle]");
          t?.setAttribute("aria-expanded", "false");
        }
      });
    });

    const mobileToggle = document.querySelector("[data-mobile-toggle]");
    const mobileMenu = document.querySelector("[data-mobile-menu]") as HTMLElement | null;
    if (mobileToggle && mobileMenu) {
      mobileToggle.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
      });
    }
  })();
</script>

<style>
  .nav-group > .nav-menu {
    display: none;
  }
  .nav-group.group-open > .nav-menu {
    display: block;
  }
</style>
