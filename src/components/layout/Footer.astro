---
import { Image } from "astro:assets";
import logo from "../../assets/home/logo.png";
import { FOOTER_MESSAGES } from "../../locales/footer";
import type { Lang } from "../../config/i18n";
import { withBase } from "../../config/urls";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const BASE = import.meta.env.BASE_URL || "/";
const footer = FOOTER_MESSAGES[lang];
const year = new Date().getFullYear();
const copyright = footer.legal.copyright.replace("{year}", String(year));

function resolveHref(href: string) {
  if (/^https?:\/\//.test(href)) return href;
  return withBase(href, BASE);
}
---

<footer class="mt-auto border-t border-border bg-background">
  <div class="mq-container py-12">
    <div class="grid grid-cols-2 md:grid-cols-6 gap-8">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <Image src={logo} alt="MindSpore Quantum" width={28} height={28} class="h-7 w-7 object-contain" loading="lazy" />
          <span class="text-xs font-semibold leading-tight">
            MindSpore<br />Quantum
          </span>
        </div>
      </div>

      {footer.columns.map((column) => (
        <div>
          <h4 class="text-sm font-semibold text-foreground mb-3">{column.title}</h4>
          <ul class="space-y-2">
            {column.links.map((link) => {
              const isExternal = /^https?:\/\//.test(link.href);
              return (
                <li>
                  <a
                    href={resolveHref(link.href)}
                    target={isExternal ? "_blank" : undefined}
                    rel={isExternal ? "noopener" : undefined}
                    class="text-sm text-muted-foreground hover:text-primary transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}

      <div>
        <h4 class="text-sm font-semibold text-foreground mb-3">{footer.followUs.title}</h4>
        <div class="w-24 h-24 bg-secondary rounded-lg flex items-center justify-center" aria-label="QR code placeholder">
          <svg viewBox="0 0 64 64" class="w-16 h-16 text-muted-foreground" aria-hidden="true">
            <g fill="currentColor">
              <rect x="4" y="4" width="16" height="16" />
              <rect x="44" y="4" width="16" height="16" />
              <rect x="4" y="44" width="16" height="16" />
              <rect x="24" y="10" width="4" height="4" />
              <rect x="34" y="10" width="4" height="4" />
              <rect x="24" y="24" width="4" height="4" />
              <rect x="34" y="24" width="4" height="4" />
              <rect x="28" y="30" width="4" height="4" />
              <rect x="40" y="28" width="4" height="4" />
              <rect x="24" y="40" width="4" height="4" />
              <rect x="34" y="44" width="4" height="4" />
              <rect x="44" y="32" width="4" height="4" />
              <rect x="54" y="32" width="4" height="4" />
              <rect x="44" y="54" width="4" height="4" />
              <rect x="54" y="44" width="4" height="4" />
              <rect x="50" y="50" width="4" height="4" />
            </g>
          </svg>
        </div>
        <p class="text-xs text-muted-foreground mt-2 leading-snug">
          {footer.followUs.description}
        </p>
      </div>
    </div>
  </div>

  <div class="border-t border-border">
    <div class="mq-container py-4 flex flex-col md:flex-row justify-between items-center gap-2 text-xs text-muted-foreground">
      <p>{copyright}</p>
      <p>{footer.legal.license}</p>
    </div>
  </div>
</footer>
