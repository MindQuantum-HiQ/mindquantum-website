---
import type { Lang } from "../../config/i18n";
import type { DocumentationMessages } from "../../locales/documentation";
import { withBase } from "../../config/urls";

interface Props {
  lang: Lang;
  messages: DocumentationMessages;
}

const { messages } = Astro.props as Props;
const BASE = import.meta.env.BASE_URL || "/";

function resolveHref(href: string) {
  if (/^https?:\/\//.test(href)) return href;
  return withBase(href, BASE);
}
---

<section class="mq-container py-10">
  <div class="flex gap-8">
    <aside class="w-60 shrink-0 hidden md:block">
      <div class="relative mb-4">
        <svg aria-hidden="true" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" viewBox="0 0 24 24">
          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.3-4.3M11 19a8 8 0 1 1 0-16a8 8 0 0 1 0 16Z" />
        </svg>
        <input
          type="search"
          placeholder={messages.searchPlaceholder}
          class="w-full rounded-lg border border-border bg-background pl-9 pr-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
        />
      </div>
      <nav class="space-y-0.5" aria-label={messages.eyebrow}>
        {messages.sidebar.map((item, index) => (
          <a
            href={resolveHref(item.href)}
            class:list={[
              "flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors",
              index === 0
                ? "text-primary font-medium bg-primary/5"
                : "text-muted-foreground hover:text-foreground hover:bg-secondary",
            ]}
          >
            <span>{item.label}</span>
            <svg aria-hidden="true" class="w-3 h-3 opacity-70" viewBox="0 0 24 24">
              <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="m9 18l6-6l-6-6" />
            </svg>
          </a>
        ))}
      </nav>
    </aside>

    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between mb-6">
        <p class="text-sm text-muted-foreground">{messages.eyebrow}</p>
        <button type="button" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-primary">
          <svg aria-hidden="true" class="w-4 h-4" viewBox="0 0 24 24">
            <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4m4-5l5 5l5-5m-5 5V3" />
          </svg>
          {messages.downloadLabel}
        </button>
      </div>

      <h1 class="text-2xl md:text-3xl font-bold text-foreground mb-8">{messages.title}</h1>

      <div class="space-y-4">
        {messages.sections.map((section) => (
          <a
            href={resolveHref(section.href)}
            class="mq-card p-6 block hover:shadow-md hover:-translate-y-0.5 transition-all group"
          >
            <h3 class="font-semibold text-foreground mb-2 group-hover:text-primary transition-colors">
              {section.title}
            </h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{section.description}</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
