---
import "../styles/tokens.css";
import "../styles/global.css";

import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { stripBase, withBase, pathForLang, detectLang } from "../config/urls";
import { LANGS, DEFAULT_LANG, type Lang } from "../config/i18n";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  fullBleed?: boolean;
  hideFooter?: boolean;
  hideHeader?: boolean;
  bodyClass?: string;
}

const {
  title = "MindQuantum",
  description = "Quantum computing with MindQuantum",
  lang,
  fullBleed = false,
  hideFooter = false,
  hideHeader = false,
  bodyClass = "",
} = Astro.props as Props;

const BASE = import.meta.env.BASE_URL || "/";
const pathUnbased = stripBase(Astro.url.pathname, BASE);
const currentLang = ((lang as Lang) || detectLang(pathUnbased)) as Lang;

// Build canonical and hreflang alternates
const hrefFor = (l: Lang) => withBase(pathForLang(pathUnbased, l), BASE);
const alternates = Object.fromEntries(
  LANGS.map((l) => [l, hrefFor(l)])
) as Record<Lang, string>;
const xDefaultHref = hrefFor(DEFAULT_LANG);
const canonicalHref = hrefFor(currentLang);
const abs = (href: string) =>
  Astro.site ? new URL(href, Astro.site).toString() : href;
---

<!doctype html>
<html lang={currentLang} data-full-bleed={fullBleed ? "true" : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#355fd4" />
    <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400..800&family=JetBrains+Mono:wght@400..500&display=swap"
    />
    <link rel="canonical" href={abs(canonicalHref)} />
    {
      Object.entries(alternates).map(([code, href]) => (
        <link rel="alternate" hreflang={code} href={abs(href)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={abs(xDefaultHref)} />
    <title>{title}</title>
  </head>
  <body class:list={["min-h-screen flex flex-col", bodyClass]}>
    <a
      href="#main-content"
      class="mq-skip-link sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:bg-background focus:text-foreground focus:border focus:border-primary focus:rounded-md focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:shadow-md"
    >
      {currentLang === "zh" ? "跳至主要内容" : "Skip to main content"}
    </a>
    {!hideHeader && <Header lang={currentLang} pathUnbased={pathUnbased} />}
    <main id="main-content" tabindex="-1" class:list={["flex-1 focus:outline-none", fullBleed ? "w-full" : ""]}>
      <slot />
    </main>
    {!hideFooter && <Footer lang={currentLang} />}
  </body>
  <script>
    // Persist preferred language for future visits
    try {
      localStorage.setItem("mq_lang", document.documentElement.lang || "en");
    } catch (e) {
      /* no-op */
    }
  </script>
  <style is:global>
    html[data-full-bleed] body {
      overflow: hidden;
    }
  </style>
</html>
